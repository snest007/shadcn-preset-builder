{
  "name": "shadcn-preset-builder",
  "description": "Figma plugin for building and applying shadcn-style presets, tokens, fonts, and radii.",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:snest007/shadcn-preset-builder.git"
  },
  "keywords": [
    "figma-plugin",
    "shadcn",
    "design-system",
    "theme"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "esbuild src/plugin/index.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife",
    "build:ui": "vite build",
    "dev": "concurrently \"npm run dev:plugin\" \"npm run dev:ui\"",
    "dev:plugin": "esbuild src/plugin/index.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife --watch",
    "dev:ui": "vite build --watch"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.97.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
